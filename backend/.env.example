# Environment
NODE_ENV=development

# Server Configuration
SERVER_PORT=8001
HOST=localhost
BASE_URL=http://localhost

# Application
APP_NAME="Agri POS"
APP_VERSION=1.0.0
APP_DESCRIPTION="Backend for Agri POS System"
SUPPORT_EMAIL=support@agripos.com
TZ=Asia/Kolkata

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=agripos

# Database Connection Pool Configuration (Performance Optimizations)
DB_CONNECTION_LIMIT=100              # Max number of connections in pool (default: 100, old: 10)
DB_QUEUE_LIMIT=50                    # Max queued connection requests (default: 50, 0 = unlimited)
DB_CONNECT_TIMEOUT=30000             # Connection timeout in ms - time to establish connection (default: 30000)
DB_MAX_IDLE=10                       # Max idle connections to maintain (default: 10)
DB_IDLE_TIMEOUT=60000                # Idle connection timeout in ms (default: 60000)

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# POS JWT Configuration (Separate from regular user JWT)
POS_JWT_SECRET=your-pos-jwt-secret-change-in-production
POS_JWT_EXPIRES_IN=365d

# Installation JWT Configuration (For 3-step installation flow)
INSTALLATION_JWT_SECRET=your-installation-jwt-secret-change-in-production
INSTALLATION_JWT_EXPIRES_IN=1h

# AWS S3 Configuration
AWS_S3_ENABLED=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=
AWS_CLOUDFRONT_URL=

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@agripos.com

# Redis Configuration (Optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

# Security Configuration
BCRYPT_ROUNDS=10
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
DB_BACKUP_TOKEN=change-this-token-in-production
API_KEY=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=5

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,application/pdf

# Logging Configuration
LOG_LEVEL=debug
LOG_MAX_FILES=14d
LOG_MAX_SIZE=20m

# Cron Jobs
BACKUP_SCHEDULE="0 2 * * *"
CLEANUP_SCHEDULE="0 2 * * *"
CLEANUP_AGE_HOURS=48

# Feature Flags
ENABLE_METRICS=true
ENABLE_HEALTH_CHECKS=true
ENABLE_BACKUPS=true
ENABLE_CLEANUP=true
ENABLE_MAINTENANCE=false

# POS Activation Configuration
ACTIVATION_ALERT_EMAIL=sales@accreteinfo.com
DB_SCRIPT_PATH=dbscript.sql
MAX_ACTIVATION_COUNT=3
DEVICE_INACTIVITY_MINUTES=15

# WhatsApp Notification Configuration (External Service)
WHATSAPP_ENABLED=false
WHATSAPP_API_URL=http://your-whatsapp-service.com/api/messages/send
WHATSAPP_MAX_RETRIES=3
WHATSAPP_TIMEOUT=30000
WHATSAPP_RETRY_DELAY=1000
WHATSAPP_CONNECTION_TIMEOUT=10000

# Frontend URLs for notifications
FRONTEND_BASE_URL=http://localhost:3000
COMPANY_NAME=AgriPOS